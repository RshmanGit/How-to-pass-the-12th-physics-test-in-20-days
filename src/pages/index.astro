---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectionGauge from '../components/ProjectionGauge.astro';
import ActivityHeatmap from '../components/ActivityHeatmap.astro';
import DayCard from '../components/DayCard.astro';
import { meta, projections, daysToPrelim, daysToFinal, papersWithProjection } from '../data/tracker';

const learnings = (await getCollection('learnings')).sort((a, b) => b.data.dayIndex - a.data.dayIndex);
const results = await getCollection('results');
const marksByDay = new Map(results.map((r) => [r.data.dayIndex, r.data.totalMarks]));
const latest = learnings.slice(0, 3);

const papers = papersWithProjection();
const hasProjection = projections.aggregate.best_pct !== null;
---

<Base title="Medicine.Daily — Today">
  <div class="wrap">
    <p class="eyebrow">Hi Mitsu 👋</p>
    <h1>Here's where you stand.</h1>

    <section class="how card">
      <p class="how-goal">🎯 <b>Goal:</b> clear all 4 theory papers — <b>≥40% each + ≥50% overall</b>.</p>
      <ol class="how-steps">
        <li><span class="ic">📖</span><b>Learn</b><span>A few high-yield questions a day, each with a ready-to-mug model answer.</span></li>
        <li><span class="ic">✍️</span><b>Test</b><span>Write them by hand, exam-style.</span></li>
        <li><span class="ic">✅</span><b>Grade</b><span>Snap a photo → marks + what to fix. Weak topics come back on their own.</span></li>
      </ol>
      <p class="how-foot">The dial below fills in once you've taken a test — one gauge per paper, so a weak paper can't hide.</p>
    </section>

    {hasProjection ? (
      <ProjectionGauge
        papers={papers}
        aggregate={projections.aggregate}
        verdict={projections.verdict}
        floorPct={meta.pass_rule.per_paper_floor_pct}
        aggregatePct={meta.pass_rule.aggregate_pct}
        daysToPrelim={daysToPrelim}
        daysToFinal={daysToFinal}
      />
    ) : (
      <section class="card empty">
        <p class="big num">{daysToPrelim}</p>
        <p>days to your prelim · <b class="num">{daysToFinal}</b> to finals. Your per-paper projection appears here after your first graded test — let's begin. 💪</p>
      </section>
    )}

    <h2>Daily streak</h2>
    <div class="card"><ActivityHeatmap /></div>

    <div class="latest-head">
      <h2>Latest study days</h2>
      <a href="/daily" class="ui see-all">See all →</a>
    </div>

    {latest.length === 0 ? (
      <p class="muted">No study days yet — the first plan lands on day 1.</p>
    ) : (
      <div class="stack">
        {latest.map((e) => (
          <DayCard
            dayIndex={e.data.dayIndex}
            date={e.data.date}
            title={e.data.title}
            systems={e.data.systems}
            totalMarks={marksByDay.get(e.data.dayIndex) ?? null}
          />
        ))}
      </div>
    )}
  </div>
</Base>

<style>
  .how { display: flex; flex-direction: column; gap: .9rem; }
  .how-goal { margin: 0; font-size: 1rem; color: var(--ink); }
  .how-goal b { color: var(--amber); }
  .how-steps {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: 1fr; gap: .8rem;
  }
  .how-steps li {
    display: grid; grid-template-columns: 2rem 1fr; gap: .2rem .7rem; align-items: start;
  }
  .how-steps .ic { grid-row: span 2; font-size: 1.5rem; line-height: 1; }
  .how-steps b { font-family: var(--font-display); color: var(--teal); }
  .how-steps span:last-child { font-size: .9rem; color: var(--text-soft); }
  .how-foot { margin: 0; font-size: .82rem; color: var(--muted); border-top: 1px solid var(--line); padding-top: .7rem; }
  @media (min-width: 560px) {
    .how-steps { grid-template-columns: repeat(3, 1fr); }
    .how-steps li { grid-template-columns: 2rem 1fr; }
  }
  .empty { text-align: center; padding: 2rem 1.2rem; }
  .empty .big { font-family: var(--font-display); font-size: 3.4rem; font-weight: 700; color: var(--amber); margin: 0; line-height: 1; }
  .empty b { color: var(--ink); }
  .latest-head { display: flex; align-items: baseline; justify-content: space-between; }
  .see-all { font-size: .82rem; font-weight: 600; color: var(--teal); text-decoration: none; }
  .stack { display: flex; flex-direction: column; gap: .9rem; }
  .muted { color: var(--muted); }
</style>
