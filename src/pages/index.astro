---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectionGauge from '../components/ProjectionGauge.astro';
import ActivityHeatmap from '../components/ActivityHeatmap.astro';
import DayCard from '../components/DayCard.astro';
import { meta, projections, daysToExam } from '../data/tracker';

const learnings = (await getCollection('learnings')).sort((a, b) => b.data.dayIndex - a.data.dayIndex);
const results = await getCollection('results');
const marksByDay = new Map(results.map((r) => [r.data.dayIndex, r.data.totalMarks]));
const latest = learnings.slice(0, 3);

const hasProjection = projections.worst !== null && projections.best !== null;
---

<Base title="Physics.Daily — Today">
  <div class="wrap">
    <p class="eyebrow">Hi Dhruvi 👋</p>
    <h1>Here's where you stand.</h1>

    {hasProjection ? (
      <ProjectionGauge
        worst={projections.worst!}
        best={projections.best!}
        passMark={meta.pass_mark}
        total={meta.total_marks}
        days={daysToExam}
      />
    ) : (
      <section class="card empty">
        <p class="big num">{daysToExam}</p>
        <p>days to the exam. Your projected score appears here after your first graded test — let's begin. 💪</p>
      </section>
    )}

    <h2>Daily streak</h2>
    <div class="card"><ActivityHeatmap /></div>

    <div class="latest-head">
      <h2>Latest study days</h2>
      <a href="/daily" class="ui see-all">See all →</a>
    </div>

    {latest.length === 0 ? (
      <p class="muted">No study days yet — the first plan lands on day 1.</p>
    ) : (
      <div class="stack">
        {latest.map((e) => (
          <DayCard
            dayIndex={e.data.dayIndex}
            date={e.data.date}
            title={e.data.title}
            chapters={e.data.chapters}
            totalMarks={marksByDay.get(e.data.dayIndex) ?? null}
          />
        ))}
      </div>
    )}
  </div>
</Base>

<style>
  .empty { text-align: center; padding: 2rem 1.2rem; }
  .empty .big { font-family: var(--font-display); font-size: 3.4rem; font-weight: 700; color: var(--amber); margin: 0; line-height: 1; }
  .latest-head { display: flex; align-items: baseline; justify-content: space-between; }
  .see-all { font-size: .82rem; font-weight: 600; color: var(--teal); text-decoration: none; }
  .stack { display: flex; flex-direction: column; gap: .9rem; }
  .muted { color: var(--muted); }
</style>
