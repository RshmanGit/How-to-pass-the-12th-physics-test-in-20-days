---
interface Props { dayIndex: number; date: Date; title: string; systems?: string[]; totalMarks?: number | null; }
const { dayIndex, date, title, systems = [], totalMarks = null } = Astro.props;
const dd = date.toLocaleDateString('en', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'UTC' });
const num = String(dayIndex).padStart(2, '0');
---

<a class="daycard card" href={`/daily/${dayIndex}`}>
  <div class="meta">
    <span class="day num">Day {num}</span>
    <span class="date num">{dd}</span>
    {typeof totalMarks === 'number' && <span class="badge num">{totalMarks} marks</span>}
  </div>
  <h3 class="title">{title}</h3>
  {systems.length > 0 && (
    <p class="chips">{systems.map((c) => <span class="chip">{c}</span>)}</p>
  )}
</a>

<style>
  .daycard { display: block; text-decoration: none; color: inherit; transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease; }
  .daycard:hover { transform: translateY(-2px); border-color: color-mix(in srgb, var(--teal) 40%, var(--line)); }
  .meta { display: flex; align-items: center; gap: .7rem; margin-bottom: .45rem; }
  .day { font-family: var(--font-display); font-weight: 700; font-size: .82rem; color: var(--amber); letter-spacing: .03em; }
  .date { font-family: var(--font-display); font-size: .78rem; color: var(--muted); }
  .badge {
    margin-left: auto; font-family: var(--font-display); font-size: .74rem; font-weight: 600;
    color: var(--teal); background: var(--teal-soft); padding: .12rem .5rem; border-radius: 999px;
  }
  .title { margin: 0 0 .5rem; font-size: 1.12rem; }
  .chips { display: flex; flex-wrap: wrap; gap: .35rem; margin: 0; }
  .chip {
    font-family: var(--font-display); font-size: .72rem; color: var(--text-soft);
    border: 1px solid var(--line); border-radius: 999px; padding: .1rem .55rem;
  }
</style>
