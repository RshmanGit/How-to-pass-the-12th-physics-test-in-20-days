---
import type { TrendPoint } from '../data/tracker';
// Two lines over time, both as % of 100: the AGGREGATE (hero, pass line at 50) and the WEAKEST PAPER
// (the binding constraint, floor line at 40). When the weakest-paper line dips under 40 the student sees
// the gate isn't met regardless of the aggregate.
interface Props { trend: TrendPoint[]; floorPct: number; aggregatePct: number; }
const { trend, floorPct, aggregatePct } = Astro.props;

const W = 320, H = 180, padL = 12, padR = 12, padT = 14, padB = 24;
const plotW = W - padL - padR, plotH = H - padT - padB;
const n = trend.length;
const x = (i: number) => (n <= 1 ? W / 2 : padL + (i / (n - 1)) * plotW);
const y = (pct: number) => padT + (1 - pct / 100) * plotH;

const weakest = (p: TrendPoint) => {
  const vals = Object.values(p.papers).filter((v): v is { worst: number; best: number } => v !== null).map((v) => v.best);
  return vals.length ? Math.min(...vals) : 0;
};
const aggLine = trend.map((p, i) => `${i ? 'L' : 'M'}${x(i).toFixed(1)},${y(p.aggregate.best_pct).toFixed(1)}`).join(' ');
const weakLine = trend.map((p, i) => `${i ? 'L' : 'M'}${x(i).toFixed(1)},${y(weakest(p)).toFixed(1)}`).join(' ');
const passY = y(aggregatePct).toFixed(1);
const floorY = y(floorPct).toFixed(1);

const short = (iso: string) => {
  const d = new Date(iso + 'T00:00:00');
  return `${d.getDate()} ${d.toLocaleString('en', { month: 'short' })}`;
};
---

<figure class="trend">
  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label="Aggregate % and weakest-paper % over time" preserveAspectRatio="xMidYMid meet">
    <line x1={padL} x2={W - padR} y1={passY} y2={passY} class="pass" />
    <text x={W - padR} y={Number(passY) - 4} class="pass-label" text-anchor="end">aggregate pass {aggregatePct}%</text>
    <line x1={padL} x2={W - padR} y1={floorY} y2={floorY} class="floor" />
    <text x={W - padR} y={Number(floorY) - 4} class="floor-label" text-anchor="end">paper floor {floorPct}%</text>

    {n >= 2 && <path d={weakLine} class="weak" />}
    {n >= 2 && <path d={aggLine} class="agg" />}

    {trend.map((p, i) => (
      <g>
        <circle cx={x(i)} cy={y(p.aggregate.best_pct)} r="3" class="dot-agg" />
        <circle cx={x(i)} cy={y(weakest(p))} r="3" class="dot-weak" />
      </g>
    ))}

    {n >= 1 && <text x={x(0)} y={H - 7} class="xlabel" text-anchor="start">{short(trend[0].date)}</text>}
    {n >= 2 && <text x={x(n - 1)} y={H - 7} class="xlabel" text-anchor="end">{short(trend[n - 1].date)}</text>}
  </svg>
  <figcaption class="legend">
    <span><i class="sw agg"></i>aggregate %</span>
    <span><i class="sw weak"></i>weakest paper %</span>
    {n <= 1 && <em>the trend fills in as each day is graded</em>}
  </figcaption>
</figure>

<style>
  .trend svg { width: 100%; height: auto; display: block; }
  .agg { fill: none; stroke: var(--amber); stroke-width: 2.5; stroke-linejoin: round; stroke-linecap: round; }
  .weak { fill: none; stroke: var(--teal); stroke-width: 2.5; stroke-linejoin: round; stroke-linecap: round; }
  .pass { stroke: var(--amber); stroke-width: 1; stroke-dasharray: 4 3; opacity: .7; }
  .floor { stroke: var(--teal); stroke-width: 1; stroke-dasharray: 4 3; opacity: .6; }
  .pass-label { fill: var(--amber); font-family: var(--font-display); font-size: 9px; font-weight: 700; }
  .floor-label { fill: var(--teal); font-family: var(--font-display); font-size: 9px; font-weight: 700; }
  .dot-agg { fill: var(--amber); }
  .dot-weak { fill: var(--teal); }
  .xlabel { fill: var(--muted); font-family: var(--font-display); font-size: 9px; }
  .legend {
    display: flex; flex-wrap: wrap; gap: .35rem 1rem; margin-top: .7rem;
    font-family: var(--font-display); font-size: .76rem; color: var(--text-soft);
  }
  .legend span { display: inline-flex; align-items: center; gap: .35rem; }
  .legend em { color: var(--muted); }
  .sw { width: 14px; height: 3px; border-radius: 2px; display: inline-block; }
  .sw.agg { background: var(--amber); }
  .sw.weak { background: var(--teal); }
</style>
